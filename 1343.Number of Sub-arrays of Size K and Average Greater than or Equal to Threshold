class Solution {
    public int numOfSubarrays(int[] arr, int k, int threshold) {
        int sum = 0, count = 0;
        int tk = threshold * k;
        for( int i = 0;i < k;i++){
            sum = sum + arr[i];
        }
        if(sum >= tk) count++;

        for(int i = k ;i<arr.length;i++){
            sum = sum - arr[i-k] + arr[i];

            if(sum >= tk) count++;
        }
       return count; 
    }
}
