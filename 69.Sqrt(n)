class Solution {
    public int mySqrt(int n) {
        int l = 1, r = n, ans = 0;
        while(l<=r){
            int mid = l + (r - l)/2;

            if((long)mid*mid == n ){
                return mid;
            }
            else if((long)mid*mid <= n){
                ans = mid;
                l = mid + 1;
            }
            else r = mid - 1;
        }
        return ans;
    }
}
